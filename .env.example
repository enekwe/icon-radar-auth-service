# Service Configuration
PORT=3001
SERVICE_NAME=auth-service
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/iconradar?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Email Configuration
EMAIL_ENABLED=true
EMAIL_PROVIDER=smtp # Options: smtp, brevo, ses
EMAIL_FROM=noreply@iconradar.com
EMAIL_FROM_NAME=Icon Radar

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=false

# Brevo (formerly Sendinblue) - Recommended
BREVO_API_KEY=your-brevo-smtp-api-key
BREVO_EMAIL=your-verified-sender-email@example.com

# AWS SES (alternative)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Security
PASSWORD_RESET_EXPIRY_MS=3600000
EMAIL_VERIFICATION_EXPIRY_MS=86400000
MAX_PASSWORD_HISTORY=5
MAX_PASSWORD_RESET_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

# Logging
LOG_LEVEL=info
